# Minos Validator Configuration
# Copy to .env: cp .env.validator.example .env

# Bittensor
NETUID=107
WALLET_NAME=default
WALLET_HOTKEY=default

# Platform
PLATFORM_URL=https://api.theminos.ai
PLATFORM_TIMEOUT=60

# Storage backend: hippius = Hippius SN75 first (fallback S3), aws_s3 = S3 first
STORAGE_PRIMARY_BACKEND=hippius

# Scoring (optional — defaults shown)
# EMA_ALPHA=0.1
# EMA_DECAY_FACTOR=0.95
# SCORING_THREADS=4
# SCORING_MEMORY_GB=8
