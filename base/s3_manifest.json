{
  "description": "Reference data paths for Minos genomics subnet",
  "ref_build": "GRCh38",
  "supported_chromosomes": ["chr1", "chr2", "chr3", "chr4", "chr5", "chr6", "chr7", "chr8", "chr9", "chr10", "chr11", "chr12", "chr13", "chr14", "chr15", "chr16", "chr17", "chr18", "chr19", "chr20", "chr21", "chr22"],
  "supported_donors": ["HG001", "HG002", "HG003", "HG004", "HG005", "HG006", "HG007"],
  "data": {
    "reference": {
      "local_pattern": "datasets/reference/{chr}/{chr}.fa",
      "s3_pattern": "https://genotypenet-platform.s3.us-east-1.amazonaws.com/reference_data/donors/reference/{chr}/{chr}.fa"
    },
    "reference_index": {
      "local_pattern": "datasets/reference/{chr}/{chr}.fa.fai",
      "s3_pattern": "https://genotypenet-platform.s3.us-east-1.amazonaws.com/reference_data/donors/reference/{chr}/{chr}.fa.fai"
    },
    "reference_dict": {
      "local_pattern": "datasets/reference/{chr}/{chr}.dict",
      "s3_pattern": "https://genotypenet-platform.s3.us-east-1.amazonaws.com/reference_data/donors/reference/{chr}/{chr}.dict"
    },
    "reference_sdf": {
      "local_pattern": "datasets/reference/{chr}/{chr}.sdf",
      "s3_pattern": "https://genotypenet-platform.s3.us-east-1.amazonaws.com/reference_data/donors/reference/{chr}/{chr}.sdf"
    }
  },
  "mutations_s3_pattern": "mutations/{donor_id}/{chromosome}/{uuid}/",
  "region_bounds": {
    "chr1": {"min_start": 5000000, "max_start": 243000000, "window_size": 5000000},
