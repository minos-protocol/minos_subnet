# Minos Miner Configuration
# Copy to .env: cp .env.miner.example .env

# Bittensor
NETUID=107
WALLET_NAME=default
WALLET_HOTKEY=default

# Demo mode: set to true to route the miner to the platform's /v2/demo/*
# sandbox instead of the live endpoints. Uses an ephemeral keypair and
# skips the on-chain registration / metagraph entirely — useful for new
# operators to verify their pipeline before bonding TAO. WALLET_* lines
# above are ignored in this mode.
# MINER_DEMO=true

# Variant Calling Template
# Options: gatk, deepvariant, bcftools
# (freebayes deprecated 2026-05-09 16:00 UTC — submissions rejected by platform)
# All require Docker. Images are pulled automatically.
MINER_TEMPLATE=gatk

# Platform
PLATFORM_URL=https://api.theminos.ai
PLATFORM_TIMEOUT=60

# Storage backend: hippius = Hippius SN75 first (fallback S3), aws_s3 = S3 first
STORAGE_PRIMARY_BACKEND=hippius
